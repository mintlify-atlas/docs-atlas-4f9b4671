{
  "projectType": "api-service",
  "projectName": "SEAM API",
  "projectDescription": "A REST API built with Node.js, Express, and MySQL that provides JWT authentication, role-based access control, permission management, and real-time events via Socket.IO.",
  "theme": "luma",
  "primaryColor": "#2563EB",
  "lightColor": "#DBEAFE",
  "darkColor": "#1E3A8A",
